@model PaymentsHomeDetailsView
@{
    ViewBag.Title = "Payments";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Membership payments</h2>
        <a asp-action="Create" class="btn btn-primary">+ New payment</a>
        @if (!string.IsNullOrEmpty(Model.ReturnUrl))
        {
            <a href="@Model.ReturnUrl" class="btn btn-secondary">← Back</a>
        }
        else{
        <a asp-action="index" asp-controller="Member" asp-route-gymid="@Model.gymid" class="btn btn-secondary"> Go Back</a>
        }
    </div>
    
      <form asp-action="index" method="get" class="d-flex gap-2 mb-3">
          <input type="hidden" name="gymid" value="@Model.gymid"/>
          <input type="text" name="search" value="@Model.search" class="form-control" placeholder="Search"/>
          <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" asp-route-gymid="@Model.gymid"asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-secondary">Clear</a>
      </form>
   
    <table class="table">
        <thead>
           <tr>
               <th>Id</th>
               <th>Member Name</th>
               <th>Plan</th>
               <th>Amount Paid</th>
               <th>Payment Date</th>
               <th>Start->EndDate</th>
                <th>Status</th>
               <th>Actions</th>
           </tr>
        </thead>
        <tbody>
            @foreach(var payment in Model.payments)
            {
                <tr>
                    <td>@payment.id</td>
                    <td>@payment.Member.MemberName</td>
                    <td>@payment.MembershipPlan.MembershipPlanName</td>
                    <td>Rs. @payment.AmountPaid.ToString("N2")</td>
                    <td>@payment.PaymentDate.ToString("dd MM yyyy")</td>
                    <td>
                        @payment.StartDate.ToString("dd MMM yyyy") →
                        <span class="@(payment.EndDate < DateTime.Now ? "text-danger fw-bold" : "")">
                            @payment.EndDate.ToString("dd MMM yyyy")
                        </span>
                    </td>
                    <td>
                        <span class="badge @(payment.Status == "Active" ? "bg-success" : "bg-secondary")">
                            @payment.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@payment.id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Delete" asp-route-id="@payment.id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            
            }
        </tbody>
    </table>
</div>
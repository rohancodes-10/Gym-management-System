@model CreatePaymentViewModel
@{
    ViewData["Title"] = "Create Payment";
    ViewData["CurrentGymId"] = Model.GymId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Index" asp-controller="MembershipPayment" asp-route-gymId="@Model.GymId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Payments
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card form-card shadow-sm">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-cash-coin form-icon"></i>
                    <h4 class="mt-2 mb-0">Create Payment</h4>
                    <p class="text-muted small">Record a membership payment</p>
                </div>

                <form asp-action="Create" asp-controller="MembershipPayment" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="MemberId" />
                    <input type="hidden" asp-for="GymId" />

                    <div class="mb-3">
                        <label class="form-label">Member</label>
                        <input type="text" value="@Model.MemberName" class="form-control" readonly />
                    </div>

                    <div class="mb-4">
                        <label asp-for="MembershipPlanId" class="form-label">Select Plan</label>
                        <select asp-for="MembershipPlanId" asp-items="@Model.MembershipPlans" class="form-select">
                            <option value="">-- Choose a Plan --</option>
                        </select>
                        <span asp-validation-for="MembershipPlanId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-circle"></i> Create Payment
                        </button>
                        <a asp-action="Index" asp-controller="MembershipPayment" asp-route-gymId="@Model.GymId" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
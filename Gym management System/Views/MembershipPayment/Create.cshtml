@model CreatePaymentViewModel
@{
    ViewBag.Title = "Creating Payment";
}


<form asp-action="Create" asp-controller="MembershipPayment" method="post" >
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="MemberId"/>
    <input type="hidden" asp-for="GymId" value="@Model.GymId" />
    <div class="mb-3">
        <label class="form-label">Member</label>
        <input type="text" value="@Model.MemberName" class="form-control" />
       
    </div>
    <div class="mb-3">
        <label asp-for="@Model.MembershipPlanId" class="form-label">Select Plan</label>
        <select asp-for="@Model.MembershipPlanId" asp-items="@Model.MembershipPlans" class="form-select">
            <option value="">--Choose a Plan</option>
        </select>
        <span asp-validation-for="@Model.MembershipPlanId" class="text-danger"></span>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            Create Payment
        </button>
        <a asp-action="Index" asp-controller="MembershipPayment"
           class="btn btn-secondary">Cancel</a>
    </div>
   
</form>
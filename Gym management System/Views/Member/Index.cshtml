
@model HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}
<h2>Members list</h2>
<div class="d-flex justify-content-end mb-3">
    <a asp-controller="Gym" asp-action="Details" asp-route-id="@Model.gymid" class="btn btn-secondary">← Back</a>
    <a asp-controller="Member" asp-action="Create" class="btn btn-primary" asp-route-gymid="@Model.gymid">Add members</a>

</div>

   <div class="row">
       
            @if(Model.members!= null && Model.members.Any())
            {
                foreach(var member in Model.members)
                { <div class="col-md-3 mb-3">

                <a asp-action="Details" asp-controller="Member" asp-route-id=@member.Id>
                    <div class="card shadow-sm">

        
                        <img src="@(string.IsNullOrEmpty(member.PhotoUrl)
                                                               ? Url.Content("~/images/Blank.jpg")
                                                               : Url.Content("~/images/" + member.PhotoUrl))"
                             class="card-img-top"
                             alt="Member Photo"
                             style="height:200px; object-fit:cover;" />

                        <div class="card-body text-center">

                
                            <h6 class="text-muted">ID: @member.Id</h6>

                
                            <h5 class="card-title">@member.MemberName</h5>

                        </div>
                      </div>
           </a>

        </div>

 
                }
            }
   </div>



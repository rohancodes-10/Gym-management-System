
@model HomeViewModel

@{
    ViewData["Title"] = "Member Details";
}
@{
    var role = Context.Session.GetString("userRole");
    var IsManager = role == "Manager";
    var IsOwner = role == "Owner";
}

<div class="container mt-4">

    <div class="card shadow-lg p-4">

        <div class="row">
            <div class="col-md-4 text-center">

                <div style="height:200px; background:#f0f0f0; display:flex; align-items:center; justify-content:center; font-size:3rem; font-weight:700; color:#ccc;">
                    @(Model.member.MemberName?.Substring(0, 1).ToUpper())
                </div>

            </div>
            <div class="col-md-8">

                <h3>@Model.member.MemberName</h3>
               

                <p><strong>ID:</strong> @Model.member.Id</p>
                <p><strong>Address:</strong> @Model.member.Address</p>
                <p><strong>Phone:</strong> @Model.member.Phone</p>
                <p><strong>Gender:</strong> @Model.member.Gender</p>
                <p><strong>City:</strong> @Model.member.city</p>
                @if (Model.member.Trainer != null)
                {
                    <p><strong>Assigned trainer:</strong> @Model.member.Trainer.TrainerName</p>
                    <a asp-action="Details" asp-controller="trainer" class="btn btn-sm btn-info ms-2" asp-route-id="@Model.member.TrainerId">Trainer Details</a>
                }
                @if(IsManager || IsOwner)
                {
                <div class="d-flex justify-content-between mt-3">

                   
                    <div>
                        <a asp-action="index" asp-controller="member" asp-route-gymid="@Model.member.GymId" class="btn btn-secondary">
                            Back to List
                        </a>

                        <a asp-controller="Member" asp-action="Edit" asp-route-Id="@Model.member.Id" class="btn btn-warning ms-2">
                        Edit
                        </a>
                            <a asp-controller="MembershipPayment" asp-action="Create" asp-route-memberId="@Model.member.Id" class="btn btn-warning ms-2">
                                Add Payment
                            </a>
                    </div>

                   
                    <div>
                       <form asp-action="Delete" asp-controller="Member" method="post" onsubmit="return confirm('Are you sure you want to delete this member')">
                            <input type="hidden" name="id" value="@Model.member.Id" />
                            <button  type="submit" class="btn btn-danger">
                                Delete
                            </button>
                       </form>
                    </div>
                   

                    <div>
                        <form asp-action="AssignTrainer" asp-controller="member" method="post">
                            <input type="hidden" name="memberid" value="@Model.member.Id"/>
                            <select asp-for="TrainerId" asp-items="@Model.Trainers">
                                <option value="">...Selcet Trainer</option>
                            </select>
                            <button type="submit" class="btn btn-primary">Assign Trainer</button>
                        </form>
                    </div>
                </div>
                }
            </div>

        </div>

    </div>

</div>
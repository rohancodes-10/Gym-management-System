@model HomeViewModel
@{
    ViewData["Title"] = "Member Details";
    var role = Context.Session.GetString("userRole");
    var isManager = role == "Manager";
    var isOwner = role == "Owner";

    ViewData["CurrentGymId"] = Model.member.GymId; // keeps sidebar alive on this page
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Index" asp-controller="Member" asp-route-gymid="@Model.member.GymId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Members
    </a>
    @if (isManager || isOwner)
    {
        <div>
            <a asp-controller="Member" asp-action="Edit" asp-route-Id="@Model.member.Id" class="btn btn-warning btn-sm">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <form asp-action="Delete" asp-controller="Member" method="post" class="d-inline"
                  onsubmit="return confirm('Are you sure you want to delete this member?')">
                <input type="hidden" name="id" value="@Model.member.Id" />
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    }
</div>

<div class="card member-detail-card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-4 align-items-center">
            <div class="col-md-3 text-center">
                <div class="member-avatar-lg mx-auto">
                    @(Model.member.MemberName?.Substring(0, 1).ToUpper())
                </div>
            </div>
            <div class="col-md-9">
                <h3 class="mb-1">@Model.member.MemberName</h3>
                <span class="badge bg-secondary mb-3">ID: @Model.member.Id</span>

                <div class="row g-3">
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Address</p>
                        <p class="mb-0"><i class="bi bi-geo-alt"></i> @Model.member.Address</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Phone</p>
                        <p class="mb-0"><i class="bi bi-telephone"></i> @Model.member.Phone</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Gender</p>
                        <p class="mb-0"><i class="bi bi-person"></i> @Model.member.Gender</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">City</p>
                        <p class="mb-0"><i class="bi bi-building"></i> @Model.member.city</p>
                    </div>
                </div>

                @if (Model.member.Trainer != null)
                {
                    <div class="mt-3 pt-3 border-top">
                        <p class="text-muted small mb-1">Assigned Trainer</p>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-person-badge"></i>
                            <strong>@Model.member.Trainer.TrainerName</strong>
                            <a asp-action="Details" asp-controller="Trainer" asp-route-id="@Model.member.TrainerId" class="btn btn-sm btn-outline-info ms-2">
                                View Trainer
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (isManager || isOwner)
{
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card member-detail-card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="mb-3"><i class="bi bi-cash-coin"></i> Payment</h6>
                    <a asp-controller="MembershipPayment" asp-action="Create" asp-route-memberId="@Model.member.Id" class="btn btn-warning w-100">
                        <i class="bi bi-plus-circle"></i> Add Payment
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card member-detail-card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="mb-3"><i class="bi bi-person-badge"></i> Trainer Assignment</h6>
                    <form asp-action="AssignTrainer" asp-controller="Member" method="post" id="assignTrainerForm">
                        <input type="hidden" name="memberid" value="@Model.member.Id" />
                        <div class="input-group">
                            <select asp-for="TrainerId" asp-items="@Model.Trainers" class="form-select">
                                <option value="">Select Trainer...</option>
                            </select>
                            <button type="submit" class="btn btn-primary">Assign</button>
                        </div>
                        <span id="trainerError" class="text-danger small mt-1" style="display:none;">
                            Please select a trainer.
                        </span>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('assignTrainerForm').addEventListener('submit', function (e) {
            const trainer = document.querySelector("select[name='TrainerId']");
            if (!trainer.value) {
                e.preventDefault();
                document.getElementById("trainerError").style.display = "block";
            }
        });
    </script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/features/member-trainer.css" asp-append-version="true" />
}
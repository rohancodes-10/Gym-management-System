@model MemberEditViewModel
@{
    ViewData["Title"] = "Edit Member";
    ViewData["CurrentGymId"] = Model.GymId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Details" asp-controller="Member" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Member
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card form-card shadow-sm">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-person form-icon"></i>
                    <h4 class="mt-2 mb-0">Edit Member</h4>
                    <p class="text-muted small">Update member details</p>
                </div>

                <form asp-action="Edit" asp-controller="Member" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="GymId" />

                    <div class="mb-3">
                        <label asp-for="MemberName" class="form-label"></label>
                        <input asp-for="MemberName" class="form-control" />
                        <span asp-validation-for="MemberName" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Age" class="form-label"></label>
                            <input asp-for="Age" class="form-control" />
                            <span asp-validation-for="Age" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label"></label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="city" class="form-label"></label>
                        <input asp-for="city" class="form-control" />
                        <span asp-validation-for="city" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-circle"></i> Update Member
                        </button>
                        <a asp-action="Details" asp-controller="Member" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
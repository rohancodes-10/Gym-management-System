@{
    var isLoggedIn = Context.Session.GetString("userId") != null;
    var userName = Context.Session.GetString("userName");
    var role = Context.Session.GetString("role"); // "Owner" or "Staff"
    var currentGymId = ViewData["CurrentGymId"] as int?;
    var showSidebar = isLoggedIn && currentGymId != null;

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gym Management System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> 
    <link rel="stylesheet" href="~/Gym_management_System.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

</head>
<body class="body-layout">

    @if (showSidebar)
    {
        <div class="app-shell">
            <!-- LEFT SIDEBAR -->
            <aside class="sidebar">
                <div class="sidebar-brand">
                    <span>💪</span> Gym Manager
                </div>

                <nav class="sidebar-nav">
                    @if (role == "Owner")
                    {
                        <a class="sidebar-link @(controller == "Gym" ? "active" : "")" asp-controller="Gym" asp-action="Index">
                            <i class="bi bi-building"></i> Gyms
                        </a>
                    }
                    <a class="sidebar-link @(controller == "Gym" ? "active" : "")"
                       asp-controller="Gym" asp-action="Details" asp-route-id="@currentGymId">
                        <i class="bi bi-info-circle"></i> Details
                    </a>
                    <div class="sidebar-dropdown">
                        <a class="sidebar-link d-flex justify-content-between align-items-center"
                           data-bs-toggle="collapse" href="#membersSubmenu" role="button"
                           aria-expanded="@(controller == "Member" ? "true" : "false")">
                            <span><i class="bi bi-people"></i> Members</span>
                            <i class="bi bi-chevron-down sidebar-caret"></i>
                        </a>
                        <div class="collapse @(controller == "Member" ? "show" : "")" id="membersSubmenu">
                            <a class="sidebar-sublink @(action == "Index" ? "active" : "")"
                               asp-controller="Member" asp-action="Index" asp-route-gymId="@currentGymId">
                                All Members
                            </a>
                            <a class="sidebar-sublink @(action == "ActiveMembers" ? "active" : "")"
                               asp-controller="MembershipPayment" asp-action="ActiveMembers" asp-route-gymId="@currentGymId">
                                Active Members
                            </a>
                            <a class="sidebar-sublink @(action == "InActiveMembers" ? "active" : "")"
                               asp-controller="MembershipPayment" asp-action="InActiveMembers" asp-route-gymId="@currentGymId">
                                Inactive Members
                            </a>
                        </div>
                    </div>
                    <a class="sidebar-link @(controller == "Trainer" ? "active" : "")"
                       asp-controller="Trainer" asp-action="Index" asp-route-gymId="@currentGymId">
                        <i class="bi bi-person-badge"></i> Trainers
                    </a>
                    <a class="sidebar-link @(controller == "Payment" ? "active" : "")"
                       asp-controller="MembershipPayment" asp-action="Index" asp-route-gymId="@currentGymId">
                        <i class="bi bi-cash-coin"></i> Payments
                    </a>
                    <a class="sidebar-link @(controller == "Plan" ? "active" : "")"
                       asp-controller="MembershipPlan" asp-action="Index" asp-route-gymId="@currentGymId">
                        <i class="bi bi-card-list"></i> Plans
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <div class="text-white-50 small mb-2">
                        Signed in as<br />
                        <strong class="text-white">@userName</strong>
                        <span class="badge bg-secondary ms-1">@role</span>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light btn-sm w-100">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </aside>

            <!-- MAIN CONTENT -->
            <div class="main-content">
                <main role="main" class="container-fluid py-4">
                    @RenderBody()
                </main>
                <footer class="text-center text-muted small py-3 border-top">
                    &copy; @DateTime.Now.Year Gym Management System
                </footer>
            </div>
        </div>
    }
    else
    {
        <!-- Login page: no sidebar -->
        <div class="page-wrapper">
            <main role="main" class="container py-4">
                @RenderBody()
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
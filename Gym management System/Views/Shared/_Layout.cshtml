@{
    var isLoggedIn = Context.Session.GetString("userId") != null;
    var userName = Context.Session.GetString("userName");
    var role = Context.Session.GetString("userRole");
    var currentGymId = ViewData["CurrentGymId"] as int?;
    var showSidebar = isLoggedIn && (currentGymId != null || role == "Trainer" || role == "Member");

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gym Management System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Gym_management_System.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="body-layout">

    @if (showSidebar)
    {
        <div class="app-shell">
            <aside class="sidebar">
                <div class="sidebar-brand">
                    <span>💪</span> Gym Manager
                </div>

                <nav class="sidebar-nav">
                    @if (role == "Owner")
                    {
                        @await Html.PartialAsync("_OwnerSidebarLinks", currentGymId)
                    }
                    else if (role == "Trainer")
                    {
                        @await Html.PartialAsync("_TrainerSidebarLinks")
                    }
                    else if (role == "Member")
                    {
                        @await Html.PartialAsync("_MemberSidebarLinks")
                    }
                </nav>

                <div class="sidebar-footer">
                    <div class="text-white-50 small mb-2">
                        Signed in as<br />
                        <strong class="text-white">@userName</strong>
                        <span class="badge bg-secondary ms-1">@role</span>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light btn-sm w-100">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </aside>

            <div class="main-content">
                <main role="main" class="container-fluid py-4">
                    @RenderBody()
                </main>
                <footer class="text-center text-muted small py-3 border-top">
                    &copy; @DateTime.Now.Year Gym Management System
                </footer>
            </div>
        </div>
    }
    else
    {
        <div class="page-wrapper">
            <main role="main" class="container py-4">
                @RenderBody()
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
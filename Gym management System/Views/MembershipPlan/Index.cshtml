@model PlansHomeViewModels
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Membership Plans</h4>
    <a asp-action="Create" asp-controller="MembershipPlan" 
       asp-route-gymId="@Model.gymid" class="btn btn-primary">+ Add Plan</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Plan Name</th>
            <th>Duration (Days)</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Plans != null && Model.Plans.Any())
        {
            @foreach (var plan in Model.Plans)
            {
                <tr>
                    <td>@plan.MembershipPlanName</td>
                    <td>@plan.DurationInDays</td>
                    <td>@plan.price.ToString("C")</td>
                    <td>
                        <a asp-action="Edit" asp-controller="MembershipPlan"
                           asp-route-id="@plan.id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-controller="MembershipPlan"
                           asp-route-id="@plan.id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">No plans found.</td>
            </tr>
        }
    </tbody>
</table>
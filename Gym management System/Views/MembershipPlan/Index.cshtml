@model PlansHomeViewModels
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Membership Plans</h4>
    <a asp-controller="Gym" asp-action="Details" asp-route-id="@Model.gymid" class="btn btn-secondary mt-2">← Back</a>
    <a asp-action="Create" asp-controller="MembershipPlan" 
       asp-route-gymId="@Model.gymid" class="btn btn-primary mt-2">+ Add Plan</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Plan Name</th>
            <th>Duration (Days)</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Plans != null && Model.Plans.Any())
        {
            @foreach (var plan in Model.Plans)
            {
                <tr>
                    <td>@plan.MembershipPlanName</td>
                    <td>@plan.DurationInDays Days</td>
                    <td>RS. @plan.price.ToString("N2")</td>
                    <td>
                       <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-controller="MembershipPlan"
                               asp-route-id="@plan.id" class="btn btn-sm btn-warning">Edit</a>
                            <form method="post" asp-route-id="@plan.id" asp-action="Delete" asp-controller="MembershipPlan" onsubmit="return('Are you sure you want to delete this plan')">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                       </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">No plans found.</td>
            </tr>
        }
    </tbody>
</table>
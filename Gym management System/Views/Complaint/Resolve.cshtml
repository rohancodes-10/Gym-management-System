@model ResolveComplaintViewModel

<h5>@Model.Subject</h5>
<p class="text-muted">From @Model.SubmittedByName (@Model.SubmittedByRole)</p>
<p>@Model.Message</p>

<form asp-action="Resolve" asp-controller="Complaint" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="GymId" />

    <div class="mb-3">
        <label asp-for="OwnerResponse" class="form-label">Your Response</label>
        <textarea asp-for="OwnerResponse" class="form-control" rows="4"></textarea>
        <span asp-validation-for="OwnerResponse" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Send Response</button>
</form>

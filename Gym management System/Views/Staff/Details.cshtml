@model StaffHomeViewModel

@{
    ViewData["Title"] = "Member Details";
}

<div class="container mt-4">

    <div class="card shadow-lg p-4">

        <div class="row">
            <div class="col-md-4 text-center">
                <img src="@(string.IsNullOrEmpty(Model.staff.PhotoUrl)
                                                                                     ? Url.Content("~/images/Blank.jpg")
                                                                                     : Url.Content("~/images/" + Model.staff.PhotoUrl))"
                     class="img-fluid rounded"
                     style="max-height:300px; object-fit:cover;" />
            </div>
            <div class="col-md-8">

                <h3>@Model.staff.StaffName</h3>
                <hr />

                <p><strong>ID:</strong> @Model.staff.Id</p>
                <p><strong>Address:</strong> @Model.staff.StaffAddress</p>
                <p><strong>Phone:</strong> @Model.staff.Phone</p>
                <p><strong>Gender:</strong> @Model.staff.Gender</p>
                <p><strong>Age:</strong> @Model.staff.Age</p>

                <div class="d-flex justify-content-between mt-3">

                   
                    <div>
                        <a asp-action="index" asp-controller="staff" asp-route-gymid="@Model.staff.GymId" class="btn btn-secondary">
                            Back to List
                        </a>

                        <a asp-controller="staff" asp-action="Edit" asp-route-Id="@Model.staff.Id" class="btn btn-warning ms-2">
                            Edit
                        </a>
                    </div>

                   
                    <div>
                        <form asp-action="Delete" asp-controller="staff" method="post" onsubmit="return confirm('Are you sure you want to delete this member')">
                            <input type="hidden" name="id" value="@Model.staff.Id" />
                            <button type="submit" class="btn btn-danger">
                                Delete
                            </button>
                        </form>
                    </div>

                </div>
            </div>

        </div>

    </div>

</div>
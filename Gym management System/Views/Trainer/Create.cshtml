@model AddTrainerViewModel
@{
    ViewData["Title"] = "Add Trainer";
    ViewData["CurrentGymId"] = Model.GymId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Index" asp-controller="Trainer" asp-route-gymid="@Model.GymId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Trainers
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card form-card shadow-sm">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus form-icon"></i>
                    <h4 class="mt-2 mb-0">Add Trainer</h4>
                    <p class="text-muted small">Enter the new trainer's details</p>
                </div>

                <form asp-action="Create" asp-controller="Trainer" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <input asp-for="GymId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="TrainerName" class="form-label"></label>
                        <input asp-for="TrainerName" class="form-control" placeholder="e.g. John Smith" />
                        <span asp-validation-for="TrainerName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" type="email" class="form-control" placeholder="trainer@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Age" class="form-label"></label>
                            <input asp-for="Age" class="form-control" />
                            <span asp-validation-for="Age" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="TrainerAddress" class="form-label"></label>
                        <input asp-for="TrainerAddress" class="form-control" />
                        <span asp-validation-for="TrainerAddress" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-circle"></i> Add Trainer
                        </button>
                        <a asp-action="Index" asp-controller="Trainer" asp-route-gymid="@Model.GymId" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Member_and_trainer_ index/Edit.css" asp-append-version="true" />
}
@model TrainerHomeViewModels
@{
    ViewData["Title"] = "Trainer Details";
    var role = Context.Session.GetString("userRole");
    var isOwner = role == "Owner";
    var isManager = role == "Manager";
    var isTrainer = role == "Trainer";

    ViewData["CurrentGymId"] = Model.trainer.GymId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Index" asp-controller="Trainer" asp-route-gymid="@Model.trainer.GymId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    @if (isOwner || isManager)
    {
        <div>
            <a asp-controller="Trainer" asp-action="Edit" asp-route-Id="@Model.trainer.Id" class="btn btn-warning btn-sm">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <form asp-action="Delete" asp-controller="Trainer" method="post" class="d-inline"
                  onsubmit="return confirm('Are you sure you want to delete this trainer?')">
                <input type="hidden" name="id" value="@Model.trainer.Id" />
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    }
</div>

<div class="card member-detail-card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-4 align-items-center">
            <div class="col-md-3 text-center">
                <div class="member-avatar-lg mx-auto">
                    @(Model.trainer.TrainerName?.Substring(0, 1).ToUpper())
                </div>
            </div>
            <div class="col-md-9">
                <h3 class="mb-1">@Model.trainer.TrainerName</h3>
                <span class="badge bg-secondary mb-3">ID: @Model.trainer.Id</span>

                <div class="row g-3">
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Address</p>
                        <p class="mb-0"><i class="bi bi-geo-alt"></i> @Model.trainer.TrainerAddress</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Phone</p>
                        <p class="mb-0"><i class="bi bi-telephone"></i> @Model.trainer.Phone</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (isOwner || isManager || isTrainer)
{
    <div class="card member-detail-card shadow-sm">
        <div class="card-body">
            <h6 class="mb-3"><i class="bi bi-people"></i> Assigned Members</h6>

            @if (Model.AssignedMember != null && Model.AssignedMember.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Age</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model.AssignedMember)
                            {
                                <tr>
                                    <td>@member.MemberName</td>
                                    <td>@member.Phone</td>
                                    <td>@member.Age</td>
                                    <td>
                                        <a asp-controller="Member" asp-action="Details" asp-route-id="@member.Id" class="btn btn-sm btn-outline-light">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No members assigned yet.</p>
            }
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/css/Member_and_trainer_index/MandTindex.css" asp-append-version="true" />
}
@model GymHomeViewModels
@{
    ViewData["Title"] = "Gyms";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="mb-0">Gyms</h2>
    <a asp-controller="Gym" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Gym
    </a>
</div>

<div class="row mb-4 g-3">
    <div class="col-md-3">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-building stat-icon text-primary"></i>
                <h6 class="text-muted mb-1">Total Gyms</h6>
                <h3 class="text-primary mb-0">@Model.TotalGyms</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-people stat-icon text-success"></i>
                <h6 class="text-muted mb-1">Total Members</h6>
                <h3 class="text-success mb-0">@Model.TotalMembers</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-person-badge stat-icon text-warning"></i>
                <h6 class="text-muted mb-1">Total Trainers</h6>
                <h3 class="text-warning mb-0">@Model.TotalTrainers</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-cash-coin stat-icon text-info"></i>
                <h6 class="text-muted mb-1">This Month Revenue</h6>
                <h3 class="text-info mb-0">Rs @Model.MonthlyRevenue.ToString("N2")</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    @if (Model.Gyms != null && Model.Gyms.Any())
    {
        foreach (var gym in Model.Gyms)
        {
            <div class="col-md-4 col-lg-3">
                <a asp-action="Details" asp-controller="Gym" asp-route-id="@gym.Id" class="text-decoration-none">
                    <div class="card gym-card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-secondary">ID: @gym.Id</span>
                            </div>
                            <h5 class="card-title mb-2">@gym.GymName</h5>
                            <p class="text-muted small mb-1">
                                <i class="bi bi-geo-alt"></i> @gym.GymAddress
                            </p>
                            <p class="text-muted small mb-1">
                                <i class="bi bi-building"></i> @gym.City
                            </p>
                            <p class="text-muted small mb-0">
                                <i class="bi bi-telephone"></i> @gym.Phone
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center mt-5">
            <i class="bi bi-building display-4 text-muted"></i>
            <h5 class="text-muted mt-3">No gyms added yet</h5>
            <a asp-controller="Gym" asp-action="Create" class="btn btn-primary mt-2">Add First Gym</a>
        </div>
    }
</div>
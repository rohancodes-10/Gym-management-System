@using Gym_management_System.ViewModels.GymViewModels;
@model GymHomeViewModels
@{
    ViewData["Title"] = "Gym Details";
    var isOwner = Context.Session.GetString("userRole") == "Owner";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Index" asp-controller="Gym" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Gyms
    </a>
    @if (isOwner)
    {
        <div>
            <a asp-action="Edit" asp-controller="Gym" asp-route-id="@Model.gym.Id" class="btn btn-warning btn-sm">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <form asp-action="Delete" asp-controller="Gym" method="post" class="d-inline"
                  onsubmit="return confirm('Delete this gym? This cannot be undone.')">
                <input type="hidden" name="id" value="@Model.gym.Id" />
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    }
</div>

<!-- Gym Info Card -->
<div class="card gym-detail-card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h3 class="mb-1">💪 @Model.gym.GymName</h3>
                <span class="badge bg-secondary">ID: @Model.gym.Id</span>
            </div>
        </div>
        <hr class="my-3" />
        <div class="row g-3">
            <div class="col-md-4">
                <p class="text-muted small mb-1">Address</p>
                <p class="mb-0"><i class="bi bi-geo-alt"></i> @Model.gym.GymAddress</p>
            </div>
            <div class="col-md-4">
                <p class="text-muted small mb-1">City</p>
                <p class="mb-0"><i class="bi bi-building"></i> @Model.gym.City</p>
            </div>
            <div class="col-md-4">
                <p class="text-muted small mb-1">Phone</p>
                <p class="mb-0"><i class="bi bi-telephone"></i> @Model.gym.Phone</p>
            </div>
        </div>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="card stat-card border-0 text-center py-3">
            <div class="stat-icon-wrap blue"><i class="bi bi-people"></i></div>
            <h6 class="text-muted mb-1">Total Members</h6>
            <h3 class="text-primary mb-0">@Model.gym.members?.Count</h3>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card border-0 text-center py-3">
            <div class="stat-icon-wrap yellow"><i class="bi bi-person-badge"></i></div>
            <h6 class="text-muted mb-1">Total Trainers</h6>
            <h3 class="text-warning mb-0">@Model.gym.trainers?.Count</h3>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card border-0 text-center py-3">
            <div class="stat-icon-wrap green"><i class="bi bi-check-circle"></i></div>
            <h6 class="text-muted mb-1">Active Members</h6>
            <h3 class="text-success mb-0">@Model.TotalActiveMembers</h3>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card border-0 text-center py-3">
            <div class="stat-icon-wrap red"><i class="bi bi-x-circle"></i></div>
            <h6 class="text-muted mb-1">Inactive Members</h6>
            <h3 class="text-danger mb-0">@Model.TotalInactiveMembers</h3>
        </div>
    </div>
</div>


@using Gym_management_System.ViewModels.GymViewModels;
@model GymHomeViewModels
@{
    ViewData["Title"] = "Gym Details";
}
@{
    var IsOwner = Context.Session.GetString("Role") == "Owner";
}
<div class="container mt-4">

    <!-- Back Button -->
    @if (IsOwner)
    {
        <div class="mb-3">
            <a asp-action="Index" asp-controller="Gym"
               class="btn btn-secondary">← Back to Gyms</a>
        </div>
    }

    <!-- Gym Info Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="card-title">💪 @Model.gym.GymName</h2>
            <hr />
            <p>📍 <strong>Address:</strong> @Model.gym.GymAddress</p>
            <p>🏙️ <strong>City:</strong> @Model.gym.City</p>
            <p>📞 <strong>Phone:</strong> @Model.gym.Phone</p>
            <p>👥 <strong>Total Members:</strong> @Model.gym.members?.Count</p>
            <p>🏃 <strong>Total Trainers:</strong> @Model.gym.trainers?.Count</p>
            <p>✅ <strong>Active Members:</strong> @Model.TotalActiveMembers</p>
            <p>❌ <strong>Inactive Members:</strong> @Model.TotalInactiveMembers</p>
        </div>

        @if (IsOwner)
        {
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-controller="Gym"
                   asp-route-id="@Model.gym.Id"
                   class="btn btn-warning">Edit</a>

                <form asp-action="Delete" asp-controller="Gym" method="post" onsubmit="return confirm('Do you want to delete TheGYm')">
                    <input type="hidden" name="id" value="@Model.gym.Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        }
    </div>
   <div class="mt-3">
        <a asp-controller="MembershipPayment"
           asp-action="ActiveMembers"
           asp-route-gymId="@Model.gym.Id"
           class="btn btn-success btn-sm">
            Active Members
        </a>
        <a asp-controller="MembershipPayment"
           asp-action="InActiveMembers"
           asp-route-gymId="@Model.gym.Id"
           class="btn btn-danger btn-sm">
            InActive Members
        </a>
   </div>
   
    <div class="card shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5>👥 Members</h5>
                <p class="text-muted mb-0">
                    @Model.gym.members?.Count members in this gym
                </p>
            </div>
            <a asp-action="Create" asp-controller="Member"
                   class="btn btn-primary" asp-route-gymid="@Model.gym.Id">
                Add Members →
            </a>
            <a asp-action="Index" asp-controller="Member"
                   class="btn btn-primary" asp-route-gymid="@Model.gym.Id">
                View Members →
            </a>
        </div>
    </div>

   
    <div class="card shadow-sm mt-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5>🏃 Trainers</h5>
                <p class="text-muted mb-0">@Model.gym.trainers?.Count Trainers in this gym</p>
            </div>
            <a class="btn btn-primary" asp-action="Create" asp-controller="Trainer" asp-route-gymid="@Model.gym.Id">
                Add Trainer
            </a>
            <a class="btn btn-primary" asp-action="index" asp-controller="Trainer" asp-route-gymid="@Model.gym.Id">
                View Trainers →
            </a>
        </div>
    </div>
    <div class="card shadow-sm mt-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5> Membership Plans</h5>
            </div>
            <a class="btn btn-primary" asp-action="Create" asp-controller="MembershipPlan" asp-route-gymid="@Model.gym.Id">
                Add Plans
            </a>
            <a class="btn btn-primary" asp-action="index" asp-controller="MembershipPlan" asp-route-gymid="@Model.gym.Id">
                View Plans →
          </a>
        </div>
    </div>
    <div class="card shadow-sm mt-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5> Payments</h5>
            </div>
            <a class="btn btn-primary" asp-action="index" asp-controller="MembershipPayment" asp-route-gymid="@Model.gym.Id" asp-route-returnUrl="@Url.Action("Details","Gym",new{id=@Model.gym.Id})">
                View Paymnts →
            </a>
        </div>
    </div>
    @if (IsOwner)
    {
        <div class="card shadow-sm mt-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <a class="btn btn-primary" asp-action="index" asp-controller="Staff" asp-route-gymid="@Model.gym.Id">
                    View Staff
                </a>
            </div>
        </div>
    }


</div>